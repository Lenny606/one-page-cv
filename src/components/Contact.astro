<section id="contact" class="py-20 border-t border-slate-200">
  <div class="mx-auto text-center">
    <h2 class="text-3xl font-bold text-slate-900 mb-2">Get in Touch</h2>
    <p class="text-slate-600 mb-12 max-w-lg mx-auto">
      I'm always open to discussing new projects, creative ideas or opportunities to be part of your visions.
    </p>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <a
        href="mailto:thomas.kravcik@gmail.com"
        class="flex flex-col items-center gap-4 p-8 rounded-3xl bg-white border border-slate-100 shadow-sm hover:border-blue-200 hover:text-blue-600 transition-all group"
      >
        <div
          class="w-14 h-14 rounded-2xl bg-blue-50 text-blue-600 flex items-center justify-center group-hover:bg-blue-600 group-hover:text-white transition-all transform group-hover:scale-110"
        >
