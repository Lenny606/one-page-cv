---
const skills = [
  { name: "PHP", category: "Language" },
  { name: "Python", category: "Language" },
  { name: "TypeScript", category: "Language" },
  { name: "Laravel", category: "Framework" },
  { name: "FastAPI", category: "Framework" },
  { name: "Node.js", category: "Runtime" },
  { name: "React", category: "Frontend" },
  { name: "Next.js", category: "Frontend" },
  { name: "Astro", category: "Frontend" },
  { name: "Langchain", category: "AI/LLM" },
  { name: "Docker", category: "DevOps" },
  { name: "Terraform", category: "IaC" },
  { name: "Helm", category: "DevOps" },
  { name: "AWS", category: "Cloud" },
  { name: "GitLab CI/CD", category: "DevOps" },
  { name: "RabbitMQ", category: "Messaging" },
  { name: "Redis", category: "Caching" },
];
---

<section id="techstack" class="py-20 border-t border-slate-200">
  <div class="space-y-12">
    <div>
      <h2 class="text-3xl font-bold text-slate-900 mb-2">Tech Stack</h2>
      <p class="text-slate-600">
        Tools and technologies I use to bring ideas to life.
      </p>
    </div>
    <div class="flex flex-wrap gap-3">
      {
        skills.map((skill) => (
          <span class="px-5 py-2.5 rounded-2xl bg-white border border-slate-100 text-slate-700 font-medium shadow-sm hover:border-blue-200 hover:text-blue-600 transition-all cursor-default">
            {skill.name}
          </span>
        ))
      }
    </div>
  </div>
</section>
