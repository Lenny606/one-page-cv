---
const currentYear = new Date().getFullYear();
---

<footer class="relative w-full overflow-hidden section-footer pt-40 pb-12 mt-20">
  <!-- Background Image with Parallax -->
  <div 
    class="absolute inset-0 z-0 bg-cover bg-center footer-bg" 
    style="background-image: url('/images/footer-bg-light.png');"
  >
  </div>
  
  <!-- Overlay Gradient for Smooth Blend from Page Content -->
  <div class="absolute inset-x-0 top-0 z-10 bg-gradient-to-b from-slate-50 via-slate-50 to-transparent h-64"></div>
  <div class="absolute inset-0 z-10 bg-white/40 backdrop-blur-[1px]"></div>

  <div class="relative z-20 max-w-5xl mx-auto px-6">
    <div class="flex flex-col items-center gap-8 border-t border-slate-200/80 pt-12">
      <div class="text-[11px] text-slate-500 font-semibold tracking-[0.3em] uppercase flex items-center gap-3">
        <span>&copy; {currentYear}</span>
        <span class="w-1.5 h-1.5 bg-blue-500/20 rounded-full"></span>
        <span>Tomáš Kravčík</span>
        <span class="w-1.5 h-1.5 bg-blue-500/20 rounded-full"></span>
        <span class="text-slate-400">Built with Astro</span>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-bg {
    transform: scale(1.2); /* Extra room for parallax */
    filter: saturate(0.6) contrast(0.9) brightness(1.02);
    mask-image: linear-gradient(to bottom, transparent, black 15%);
    -webkit-mask-image: linear-gradient(to bottom, transparent, black 15%);
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const footer = document.querySelector('.section-footer');
  const footerBg = document.querySelector('.footer-bg');

  if (footer && footerBg) {
    // Parallax effect
    gsap.to(footerBg, {
      y: '15%',
      ease: 'none',
      scrollTrigger: {
        trigger: footer,
        start: 'top bottom',
        end: 'bottom top',
        scrub: 1.2
      }
    });

    // Suble reveal for the copyright line
    gsap.from('.section-footer .relative.z-20', {
      opacity: 0,
      y: 20,
      duration: 2,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: footer,
        start: 'top 95%',
        toggleActions: 'play none none none'
      }
    });
  }
</script>
