---
---

<div id="dot-container" class="fixed inset-0 -z-10 bg-white pointer-events-none">
  <canvas id="dot-canvas" class="w-full h-full"></canvas>
</div>

<script>

  interface Dot {
    x: number;
    y: number;
    originalX: number;
    originalY: number;
    size: number;
    color: string;
    opacity: number;
  }

  class DotBackground {
    canvas: HTMLCanvasElement;
    ctx: CanvasRenderingContext2D;
    dots: Dot[] = [];
    spacing: number = 30;
    mouse: { x: number; y: number } = { x: -1000, y: -1000 };
    radius: number = 1.5;
    hoverRadius: number = 100;
    width: number = 0;
    height: number = 0;

    constructor() {
      this.canvas = document.getElementById('dot-canvas') as HTMLCanvasElement;
      this.ctx = this.canvas.getContext('2d')!;
      
      this.init();
      this.animate();
      this.addEventListeners();
    }

    init() {
      this.resize();
      this.createDots();
    }

    resize() {
      this.width = window.innerWidth;
      this.height = window.innerHeight;
      this.canvas.width = this.width * window.devicePixelRatio;
      this.canvas.height = this.height * window.devicePixelRatio;
      this.ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
    }

    createDots() {
      this.dots = [];
      for (let x = 0; x < this.width; x += this.spacing) {
        for (let y = 0; y < this.height; y += this.spacing) {
          this.dots.push({
            x,
            y,
            originalX: x,
            originalY: y,
            size: this.radius,
            color: '#000000',
            opacity: 0.1
          });
        }
      }
    }

    addEventListeners() {
      window.addEventListener('mousemove', (e) => {
        this.mouse.x = e.clientX;
        this.mouse.y = e.clientY;
      });

      window.addEventListener('resize', () => {
        this.init();
      });
    }

    animate() {
      this.ctx.clearRect(0, 0, this.width, this.height);

      this.dots.forEach((dot: Dot) => {
        const dx = this.mouse.x - dot.x;
        const dy = this.mouse.y - dot.y;
        const distance = Math.sqrt(dx * dx + dy * dy);

        if (distance < this.hoverRadius) {
          const factor = 1 - distance / this.hoverRadius;
          dot.size = this.radius + (4 * factor);
          dot.opacity = 0.1 + (0.4 * factor);
          dot.color = '#3b82f6'; // blue-500
        } else {
          dot.size = this.radius;
          dot.opacity = 0.1;
          dot.color = '#000000';
        }

        this.ctx.beginPath();
        this.ctx.arc(dot.x, dot.y, dot.size, 0, Math.PI * 2);
        this.ctx.fillStyle = dot.color;
        this.ctx.globalAlpha = dot.opacity;
        this.ctx.fill();
        this.ctx.closePath();
      });

      requestAnimationFrame(() => this.animate());
    }
  }

  // Initialize background
  new DotBackground();
</script>

<style>
  #dot-container {
    opacity: 0.8;
  }
</style>
