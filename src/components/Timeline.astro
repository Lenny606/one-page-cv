---
const experiences = [
  {
    role: "Senior Backend Engineer",
    company: "ScaleOps Systems",
    period: "2021 — Present",
    description:
      "Architecting distributed microservices handling 100k+ RPM. Optimized database queries reducing latency by 45% and established sub-second data consistency across global regions.",
  },
  {
    role: "Full Stack Engineer (Backend Focus)",
    company: "DataFlow Logic",
    period: "2018 — 2021",
    description:
      "Designed and implemented robust REST and GraphQL APIs. Managed AWS infrastructure using Terraform and improved CI/CD pipelines, reducing deployment time by 60%.",
  },
  {
    role: "Software Developer",
    company: "CoreBackend Solutions",
    period: "2016 — 2018",
    description:
      "Developed and maintained scalable server-side logic and integrated third-party payment gateways. Focused on security auditing and database schema optimization.",
  },
  {
    role: "Arval sro",
    company: "purchasing specialist",
    period: "2016 — 2018",
    description:
      "Developed and maintained scalable server-side logic and integrated third-party payment gateways. Focused on security auditing and database schema optimization.",
  },
];
const initialExperiences = experiences.slice(0, 3);
const hiddenExperiences = experiences.slice(3);
---

<section id="timeline" class="py-20 border-t border-slate-200">
  <div class="space-y-12">
    <div>
      <h2 class="text-3xl font-bold text-slate-900 mb-2">Experience</h2>
      <p class="text-slate-600">A journey through my professional life.</p>
    </div>

    <div
      class="space-y-8 relative before:absolute before:inset-0 before:ml-5 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-0.5 before:bg-gradient-to-b before:from-transparent before:via-slate-300 before:to-transparent"
    >
      {/* Initial Experiences */}
      {
        initialExperiences.map((exp, index) => (
          <div class="relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group is-active">
            <div class="flex items-center justify-center w-10 h-10 rounded-full border border-white bg-slate-50 text-slate-300 shadow shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2">
              <svg
                class="fill-current"
                viewBox="0 0 12 12"
                width="12"
                height="12"
              >
                <path d="M12 10v2H7V8.496a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5V12H0V4.496a.5.5 0 0 1 .206-.4l5.507-3.923a.5.5 0 0 1 .587 0l5.507 3.923a.5.5 0 0 1 .206.4V10Z" />
              </svg>
            </div>
            <div class="w-[calc(100%-4rem)] md:w-[45%] p-6 rounded-2xl bg-white border border-slate-100 shadow-sm hover:shadow-md transition-shadow">
              <div class="flex items-center justify-between space-x-2 mb-1">
                <div class="font-bold text-slate-900">{exp.role}</div>
                <time class="font-medium text-blue-600 text-sm">
                  {exp.period}
                </time>
              </div>
              <div class="text-slate-500 font-medium mb-2">{exp.company}</div>
              <div class="text-slate-600 leading-relaxed text-sm">
                {exp.description}
              </div>
            </div>
          </div>
        ))
      }

      {/* Hidden Experiences Container */}
      <div id="experience-more" class="h-0 overflow-hidden space-y-8 relative">
        {
          hiddenExperiences.map((exp, index) => (
            <div class="relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group is-active py-4">
              <div class="flex items-center justify-center w-10 h-10 rounded-full border border-white bg-slate-50 text-slate-300 shadow shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2">
                <svg
                  class="fill-current"
                  viewBox="0 0 12 12"
                  width="12"
                  height="12"
                >
                  <path d="M12 10v2H7V8.496a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5V12H0V4.496a.5.5 0 0 1 .206-.4l5.507-3.923a.5.5 0 0 1 .587 0l5.507 3.923a.5.5 0 0 1 .206.4V10Z" />
                </svg>
              </div>
              <div class="w-[calc(100%-4rem)] md:w-[45%] p-6 rounded-2xl bg-white border border-slate-100 shadow-sm hover:shadow-md transition-shadow">
                <div class="flex items-center justify-between space-x-2 mb-1">
                  <div class="font-bold text-slate-900">{exp.role}</div>
                  <time class="font-medium text-blue-600 text-sm">
                    {exp.period}
                  </time>
                </div>
                <div class="text-slate-500 font-medium mb-2">{exp.company}</div>
                <div class="text-slate-600 leading-relaxed text-sm">
                  {exp.description}
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    {/* Toggle Button */}
    <div class="flex justify-center mt-8">
      <button
        id="toggle-experience"
        class="group flex items-center gap-2 px-6 py-3 rounded-2xl bg-white border border-slate-100 text-slate-600 font-semibold shadow-sm hover:border-blue-200 hover:text-blue-600 transition-all"
      >
        <span id="btn-text">Show More</span>
        <svg
          id="btn-icon"
          class="w-4 h-4 transition-transform duration-300"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </button>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";

  const initTimelineReveal = () => {
    const toggleBtn = document.getElementById("toggle-experience");
    const content = document.getElementById("experience-more");
    const btnText = document.getElementById("btn-text");
    const btnIcon = document.getElementById("btn-icon");

    if (!toggleBtn || !content || !btnText || !btnIcon) return;

    let isOpen = false;

    toggleBtn.addEventListener("click", () => {
      isOpen = !isOpen;

      if (isOpen) {
        // Open
        gsap.to(content, {
          height: "auto",
          duration: 0.8,
          ease: "expo.out",
          opacity: 1,
        });

        btnText.textContent = "Show Less";
        btnIcon.style.transform = "rotate(180deg)";
      } else {
        // Close
        gsap.to(content, {
          height: 0,
          duration: 0.6,
          ease: "expo.inOut",
          opacity: 0,
        });

        btnText.textContent = "Show More";
        btnIcon.style.transform = "rotate(0deg)";
      }
    });

    // Handle hover effect with GSAP
    toggleBtn.addEventListener("mouseenter", () => {
      gsap.to(toggleBtn, { scale: 1.02, duration: 0.3, ease: "power2.out" });
    });
    toggleBtn.addEventListener("mouseleave", () => {
      gsap.to(toggleBtn, { scale: 1, duration: 0.3, ease: "power2.out" });
    });
  };

  // Run on page load and view transitions
  document.addEventListener("DOMContentLoaded", initTimelineReveal);
  document.addEventListener("astro:page-load", initTimelineReveal);
</script>
