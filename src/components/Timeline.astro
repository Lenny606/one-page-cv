---
import experiences from '../data/experience.json';

const initialExperiences = experiences.slice(0, 3);
const hiddenExperiences = experiences.slice(3);
---

<section id="timeline" class="py-20 border-t border-slate-200">
  <div class="space-y-12">
    <div>
      <h2 class="text-3xl font-bold text-slate-900 mb-2">Experience</h2>
      <p class="text-slate-600">
        A journey through my professional life as a developer.
      </p>
    </div>

    <div id="timeline-wrap" class="relative">
      {/* Static gray track */}
      <div
        class="timeline-track absolute left-[17px] top-2 bottom-2 w-0.5 rounded-full bg-slate-200"
      >
      </div>
      {/* Colored progress line that fills on scroll */}
      <div
        class="timeline-progress absolute left-[17px] top-2 bottom-2 w-0.5 rounded-full bg-gradient-to-b from-blue-500 via-blue-500 to-indigo-500"
      >
      </div>

      <div class="space-y-8">
        {/* Initial Experiences */}
        {
          initialExperiences.map((exp) => (
            <div class="timeline-item relative pl-16">
              <span class="timeline-dot absolute left-0 top-0 flex items-center justify-center w-9 h-9 rounded-full border-2 bg-white">
                <svg
                  class="fill-current"
                  viewBox="0 0 12 12"
                  width="12"
                  height="12"
                >
                  <path d="M12 10v2H7V8.496a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5V12H0V4.496a.5.5 0 0 1 .206-.4l5.507-3.923a.5.5 0 0 1 .587 0l5.507 3.923a.5.5 0 0 1 .206.4V10Z" />
                </svg>
              </span>
              <div class="timeline-card p-6 rounded-2xl bg-white border border-slate-100 shadow-sm hover:shadow-md transition-shadow">
                <div class="flex items-center justify-between space-x-2 mb-1">
                  <div class="font-bold text-slate-900">{exp.role}</div>
                  <time class="font-medium text-blue-600 text-sm">
                    {exp.period}
                  </time>
                </div>
                <div class="text-slate-500 font-medium mb-2">{exp.company}</div>
                <div class="text-slate-600 leading-relaxed text-sm">
                  {exp.description}
                </div>
              </div>
            </div>
          ))
        }

        {/* Hidden Experiences Container */}
        {/* -mx-2 px-2: keep layout identical while giving the overflow-hidden
            clip box horizontal slack so active dots' glow isn't sliced. */}
        <div
          id="experience-more"
          class="h-0 overflow-hidden -mx-2 px-2 space-y-8"
        >
          {
            hiddenExperiences.map((exp) => (
              <div class="timeline-item relative pl-16">
                <span class="timeline-dot absolute left-0 top-0 flex items-center justify-center w-9 h-9 rounded-full border-2 bg-white">
                  <svg
                    class="fill-current"
                    viewBox="0 0 12 12"
                    width="12"
                    height="12"
                  >
                    <path d="M12 10v2H7V8.496a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5V12H0V4.496a.5.5 0 0 1 .206-.4l5.507-3.923a.5.5 0 0 1 .587 0l5.507 3.923a.5.5 0 0 1 .206.4V10Z" />
                  </svg>
                </span>
                <div class="timeline-card p-6 rounded-2xl bg-white border border-slate-100 shadow-sm hover:shadow-md transition-shadow">
                  <div class="flex items-center justify-between space-x-2 mb-1">
                    <div class="font-bold text-slate-900">{exp.role}</div>
                    <time class="font-medium text-blue-600 text-sm">
                      {exp.period}
                    </time>
                  </div>
                  <div class="text-slate-500 font-medium mb-2">
                    {exp.company}
                  </div>
                  <div class="text-slate-600 leading-relaxed text-sm">
                    {exp.description}
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    {/* Toggle Button */}
    <div class="flex justify-center mt-8">
      <button
        id="toggle-experience"
        class="group flex items-center gap-2 px-6 py-3 rounded-2xl bg-white border border-slate-100 text-slate-600 font-semibold shadow-sm hover:border-blue-200 hover:text-blue-600 transition-all"
      >
        <span id="btn-text">Show More Working Experience</span>
        <svg
          id="btn-icon"
          class="w-4 h-4 transition-transform duration-300"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </button>
    </div>
  </div>
</section>

<style>
  /* Dot: muted by default, colored once the scroll progress reaches it */
  .timeline-dot {
    border-color: var(--color-slate-200, #e2e8f0);
    color: var(--color-slate-300, #cbd5e1);
    transition:
      color 0.4s ease,
      background-color 0.4s ease,
      border-color 0.4s ease,
      box-shadow 0.4s ease,
      transform 0.4s ease;
  }

  .timeline-item.is-active .timeline-dot {
    border-color: var(--color-blue-500, #3b82f6);
    background-color: var(--color-blue-500, #3b82f6);
    color: #fff;
    transform: scale(1.1);
    box-shadow: 0 0 0 4px rgb(59 130 246 / 0.15);
  }

  /* Progress line starts empty; GSAP scrubs scaleY from 0 -> 1 on scroll */
  .timeline-progress {
    transform: scaleY(0);
    transform-origin: top center;
  }

  @media (prefers-reduced-motion: reduce) {
    .timeline-dot {
      transition: none;
    }
    .timeline-progress {
      transform: scaleY(1);
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const initTimeline = () => {
    const wrap = document.getElementById('timeline-wrap');
    const progress = wrap?.querySelector<HTMLElement>('.timeline-progress');
    const items = gsap.utils.toArray<HTMLElement>('.timeline-item');

    if (!wrap || !progress || items.length === 0) return;

    const prefersReducedMotion = window.matchMedia(
      '(prefers-reduced-motion: reduce)'
    ).matches;

    if (prefersReducedMotion) {
      // Show everything in its final, colored state without scroll effects.
      gsap.set(progress, { scaleY: 1 });
      items.forEach((item) => item.classList.add('is-active'));
      return;
    }

    // Fill the colored line as the section scrolls through the viewport.
    gsap.to(progress, {
      scaleY: 1,
      ease: 'none',
      scrollTrigger: {
        trigger: wrap,
        start: 'top center',
        end: 'bottom center',
        scrub: 0.5,
      },
    });

    // Light up each dot when the colored fill reaches it.
    items.forEach((item) => {
      ScrollTrigger.create({
        trigger: item,
        start: 'top center',
        onEnter: () => item.classList.add('is-active'),
        onLeaveBack: () => item.classList.remove('is-active'),
      });
    });
  };

  const initToggle = () => {
    const toggleBtn = document.getElementById('toggle-experience');
    const content = document.getElementById('experience-more');
    const btnText = document.getElementById('btn-text');
    const btnIcon = document.getElementById('btn-icon');

    if (!toggleBtn || !content || !btnText || !btnIcon) return;

    let isOpen = false;

    toggleBtn.addEventListener('click', () => {
      isOpen = !isOpen;

      gsap.to(content, {
        height: isOpen ? 'auto' : 0,
        opacity: isOpen ? 1 : 0,
        duration: isOpen ? 0.8 : 0.6,
        ease: isOpen ? 'expo.out' : 'expo.inOut',
        // Recalculate ScrollTrigger positions once the layout settles so the
        // newly revealed (or hidden) items drive the progress line correctly.
        onComplete: () => ScrollTrigger.refresh(),
      });

      btnText.textContent = isOpen
        ? 'Show Less'
        : 'Show More Working Experience';
      btnIcon.style.transform = isOpen ? 'rotate(180deg)' : 'rotate(0deg)';
    });

    toggleBtn.addEventListener('mouseenter', () => {
      gsap.to(toggleBtn, { scale: 1.02, duration: 0.3, ease: 'power2.out' });
    });
    toggleBtn.addEventListener('mouseleave', () => {
      gsap.to(toggleBtn, { scale: 1, duration: 0.3, ease: 'power2.out' });
    });
  };

  const init = () => {
    initTimeline();
    initToggle();
  };

  document.addEventListener('DOMContentLoaded', init);
  document.addEventListener('astro:page-load', init);
</script>
