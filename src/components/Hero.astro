---
const projects = [
  {
    id: 'jenko-studio',
    title: 'Jenko Studio',
    shortDesc: 'Digital gallery showcasing abstract art and minimal experiments.',
    longDesc: 'A minimalist digital portfolio for artist Dominika Jenčová, focusing on emotional storytelling through abstract expressions. Designed with a clean, immersive user interface that lets the art speak for itself.',
    tech: ['Astro', 'GSAP', 'Tailwind', 'JavaScript'],
    challenge: 'Creating a layout that feels as fluid and abstract as the artwork it presents.',
    solution: 'Implemented sophisticated GSAP animations and a flexible grid system to mirror the artist\'s style.',
    link: 'https://jenkostudio.com'
  },
  {
    id: 'dbda-studio',
    title: 'DBDA studio',
    shortDesc: 'Modern architectural atelier project showcase.',
    longDesc: 'A professional platform for a Prague-based architectural studio. The site presents modern architectural designs that harmonize with landscape and history, requiring a structured yet elegant presentation of large-scale projects.',
    tech: ['Astro', 'ExpressJS', 'PostgreSQL', 'Tailwind'],
    challenge: 'Maintaining high performance while displaying high-resolution architectural project galleries.',
    solution: 'Developed a custom image optimization pipeline and a clean, project-focused navigation system.',
    link: 'https://dbda.cz'
  },
  {
    id: 'animation-flow',
    title: 'Animation Flow',
    shortDesc: 'Creative coding and animation orchestration engine.',
    longDesc: 'A specialized engine for building complex, timeline-based animations using GSAP and Python, bridging the gap between design and logic.',
    tech: ['Python', 'GSAP', 'JavaScript', 'SVG'],
    challenge: 'Synchronizing multi-step animations across different viewports.',
    solution: 'Developed a custom state-driven animation manager for precise timing control.',
    link: 'https://github.com/Lenny606/animation-flow'
  }
];
---

<header id="hero" class="min-h-[80vh] flex flex-col justify-center py-20 relative">
  <div class="space-y-6">
    <span class="gsap-hero-badge invisible inline-block px-4 py-1.5 rounded-full bg-blue-50 text-blue-600 text-xs font-bold tracking-widest uppercase mb-4">
      Available for new opportunities
    </span>
    <h1 class="gsap-hero-title invisible text-6xl md:text-9xl font-black tracking-tighter text-slate-900 leading-[0.9] md:leading-[0.85]">
      Building <br />
      <span class="text-transparent bg-clip-text bg-gradient-to-br from-blue-600 to-blue-400 drop-shadow-sm">efficient</span><br />
      backends.
    </h1>
    <p class="gsap-hero-description invisible text-xl md:text-2xl text-slate-600 max-w-xl leading-relaxed mt-4">
      Backend Developer focused on full-stack solutions and delivering robust, scalable systems.
    </p>
    <div class="gsap-hero-actions invisible flex flex-wrap gap-4 pt-4">
      <a href="#contact" class="gsap-btn px-8 py-4 bg-slate-900 text-white rounded-2xl font-bold hover:bg-slate-800 transition-all shadow-xl shadow-slate-200">
        Get in touch
      </a>
      <button id="view-work-toggle" class="gsap-btn px-8 py-4 bg-white border border-slate-100 text-slate-600 rounded-2xl font-bold shadow-sm hover:border-blue-200 hover:text-blue-600 transition-all flex items-center gap-2 group cursor-pointer">
        View work
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="chevron-icon transition-transform duration-300"><polyline points="6 9 12 15 18 9"></polyline></svg>
      </button>
      <a href="https://github.com/Lenny606" target="_blank" class="gsap-btn px-8 py-4 bg-white border border-slate-100 text-slate-600 rounded-2xl font-bold shadow-sm hover:border-blue-200 hover:text-blue-600 transition-all flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-slate-900"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
        GitHub
      </a>
    </div>

    <!-- Expandable Section -->
    <div id="expandable-work" class="h-0 overflow-hidden opacity-0 pointer-events-none mt-8 border-t border-slate-100 transition-all duration-300">
      <div class="py-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {projects.map((project) => (
          <div 
            class="project-card group relative h-64 rounded-3xl bg-white border border-slate-100 shadow-sm hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 flex flex-col justify-between p-8 cursor-pointer overflow-hidden"
            data-project={JSON.stringify(project)}
          >
            <!-- Decorative background gradient -->
            <div class="absolute inset-0 bg-gradient-to-br from-blue-50/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            
            <div class="relative z-10">
              <div class="flex flex-wrap gap-2 mb-4">
                {project.tech.slice(0, 2).map((t) => (
                  <span class="px-2 py-0.5 rounded-md bg-slate-50 text-slate-500 text-[10px] font-bold uppercase tracking-wider border border-slate-100">
                    {t}
                  </span>
                ))}
              </div>
              <h3 class="text-2xl font-black text-slate-900 group-hover:text-blue-600 transition-colors uppercase tracking-tight">
                {project.title}
              </h3>
            </div>
            
            <div class="relative z-10 flex items-center justify-between">
              <p class="text-sm text-slate-500 font-medium max-w-[70%] leading-snug">
                {project.shortDesc}
              </p>
              <div class="w-10 h-10 rounded-full bg-slate-900 text-white flex items-center justify-center -rotate-45 group-hover:rotate-0 group-hover:bg-blue-600 transition-all duration-500">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Project Detail Modal -->
  <div id="project-modal" class="fixed inset-0 z-[100] flex items-center justify-center p-4 md:p-8 invisible opacity-0 pointer-events-none transition-all duration-300">
    <!-- Backdrop with vibrant glassmorphism -->
    <div class="modal-backdrop absolute inset-0 bg-slate-900/40 backdrop-blur-xl"></div>
    
    <!-- Modal Content -->
    <div class="modal-content relative w-full max-w-2xl bg-white rounded-[2rem] shadow-2xl overflow-hidden translate-y-8">
      <button id="close-modal" class="absolute top-6 right-6 w-12 h-12 rounded-full bg-slate-50 text-slate-400 hover:text-slate-900 hover:bg-slate-100 flex items-center justify-center transition-all z-20 group">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:rotate-90 transition-transform duration-300"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>

      <div class="p-8 md:p-12 space-y-8">
        <div class="space-y-4">
          <div id="modal-tags" class="flex flex-wrap gap-2"></div>
          <h2 id="modal-title" class="text-4xl md:text-5xl font-black text-slate-900 tracking-tighter uppercase leading-none"></h2>
        </div>

        <p id="modal-desc" class="text-lg text-slate-600 leading-relaxed"></p>

        <div class="grid md:grid-cols-2 gap-8">
          <div class="space-y-3">
            <h4 class="text-xs font-bold uppercase tracking-widest text-blue-600">Challenge</h4>
            <p id="modal-challenge" class="text-sm text-slate-500 leading-relaxed"></p>
          </div>
          <div class="space-y-3">
            <h4 class="text-xs font-bold uppercase tracking-widest text-emerald-600">Solution</h4>
            <p id="modal-solution" class="text-sm text-slate-500 leading-relaxed"></p>
          </div>
        </div>

        <div class="pt-6">
          <a id="modal-link" href="#" target="_blank" class="inline-flex items-center gap-3 px-8 py-4 bg-slate-900 text-white rounded-2xl font-bold hover:bg-blue-600 transition-all shadow-xl shadow-slate-200 group text-lg">
            View Source Code
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  import { gsap } from 'gsap';

  const initHeroAnimations = () => {
    const tl = gsap.timeline({ defaults: { ease: "expo.out", duration: 1.5 } });

    gsap.set(['.gsap-hero-badge', '.gsap-hero-title', '.gsap-hero-description', '.gsap-hero-actions'], { 
      visibility: 'visible' 
    });

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (prefersReducedMotion) {
      tl.from(['.gsap-hero-badge', '.gsap-hero-title', '.gsap-hero-description', '.gsap-hero-actions'], {
        opacity: 0,
        duration: 0.8,
        stagger: 0.1
      });
      return;
    }

    tl.from('.gsap-hero-badge', {
      opacity: 0,
      y: 30,
      duration: 1,
    })
    .from('.gsap-hero-title', {
      opacity: 0,
      y: 100,
      rotateX: -20,
      transformOrigin: "top left",
      stagger: 0.1,
    }, "-=1.2")
    .from('.gsap-hero-description', {
      opacity: 0,
      y: 30,
    }, "-=1.2")
    .from('.gsap-hero-actions', {
      opacity: 0,
      y: 30,
      stagger: 0.1
    }, "-=1.2");

    // Button interactions
    const buttons = document.querySelectorAll('.gsap-btn');
    buttons.forEach(btn => {
      btn.addEventListener('mouseenter', () => {
        gsap.to(btn, { scale: 1.05, y: -2, duration: 0.4, ease: "power3.out" });
      });
      btn.addEventListener('mouseleave', () => {
        gsap.to(btn, { scale: 1, y: 0, duration: 0.4, ease: "power3.out" });
      });
    });
  };

  const initExpandableSection = () => {
    const toggleBtn = document.getElementById('view-work-toggle');
    const section = document.getElementById('expandable-work');
    const chevron = toggleBtn?.querySelector('.chevron-icon');
    
    if (!toggleBtn || !section || !chevron) return;

    let isOpen = false;

    /**
     * Toggles the visibility of the "View work" grid section.
     * Uses GSAP for smooth height and opacity transitions.
     */
    toggleBtn.addEventListener('click', () => {
      isOpen = !isOpen;
      
      if (isOpen) {
        // Open the section
        gsap.to(section, {
          height: 'auto',
          opacity: 1,
          duration: 0.8,
          ease: "expo.out",
          pointerEvents: 'auto',
          onStart: () => {
            section.classList.remove('pointer-events-none');
          }
        });
        
        // Rotate the chevron
        gsap.to(chevron, { rotate: 180, duration: 0.4, ease: "power3.out" });
        
        // Stagger project cards in for a premium look
        gsap.from('.project-card', {
          opacity: 0,
          y: 40,
          stagger: 0.1,
          duration: 0.8,
          ease: "expo.out",
          clearProps: "all"
        });
      } else {
        // Close the section
        gsap.to(section, {
          height: 0,
          opacity: 0,
          duration: 0.5,
          ease: "power3.inOut",
          pointerEvents: 'none',
          onComplete: () => {
            section.classList.add('pointer-events-none');
          }
        });
        
        // Reset the chevron rotation
        gsap.to(chevron, { rotate: 0, duration: 0.4, ease: "power3.inOut" });
      }
    });

    // Modal Logic for project details
    const modal = document.getElementById('project-modal');
    const cards = document.querySelectorAll('.project-card');
    const closeBtn = document.getElementById('close-modal');
    const backdrop = modal?.querySelector('.modal-backdrop');

    const openModal = (project) => {
      if (!modal) return;
      
      const title = modal.querySelector('#modal-title');
      const desc = modal.querySelector('#modal-desc');
      const challenge = modal.querySelector('#modal-challenge');
      const solution = modal.querySelector('#modal-solution');
      const link = modal.querySelector('#modal-link');
      const tags = modal.querySelector('#modal-tags');

      if (title) title.textContent = project.title;
      if (desc) desc.textContent = project.longDesc;
      if (challenge) challenge.textContent = project.challenge;
      if (solution) solution.textContent = project.solution;
      if (link) link.setAttribute('href', project.link);
      
      if (tags) {
        tags.innerHTML = project.tech.map(t => `
          <span class="px-3 py-1 rounded-full bg-slate-100 text-slate-600 text-[10px] font-black uppercase tracking-widest border border-slate-200">
            ${t}
          </span>
        `).join('');
      }

      gsap.to(modal, { autoAlpha: 1, pointerEvents: 'auto', duration: 0.4 });
      gsap.fromTo('.modal-content', 
        { y: 50, scale: 0.95, opacity: 0 },
        { y: 0, scale: 1, opacity: 1, duration: 0.6, ease: "expo.out" }
      );
    };

    const closeModal = () => {
      if (!modal) return;
      gsap.to('.modal-content', { y: 30, scale: 0.95, opacity: 0, duration: 0.4, ease: "power3.in" });
      gsap.to(modal, { autoAlpha: 0, pointerEvents: 'none', duration: 0.4 });
    };

    cards.forEach(card => {
      card.addEventListener('click', () => {
        const projectData = JSON.parse(card.getAttribute('data-project') || '{}');
        openModal(projectData);
      });
    });

    closeBtn?.addEventListener('click', closeModal);
    backdrop?.addEventListener('click', closeModal);
    
    window.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeModal();
    });
  };

  document.addEventListener('DOMContentLoaded', () => {
    initHeroAnimations();
    initExpandableSection();
  });
  document.addEventListener('astro:page-load', () => {
    initHeroAnimations();
    initExpandableSection();
  });
</script>
