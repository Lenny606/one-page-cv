---
const impacts = [
  {
    title: 'E-commerce & Logistics',
    description: 'Architected robust backend systems for complex e-commerce and logistics platforms, ensuring smooth data flow and high reliability for direct client services.',
    icon: '<path d="m7.5 4.27 9 5.15"></path><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"></path><path d="m3.3 7 8.7 5 8.7-5"></path><path d="M12 22V12"></path>'
  },
  {
    title: 'Modern API Architecture',
    description: 'Designed and implemented secure, scalable API services using Laravel, Slim, and FastAPI, prioritizing developer experience and system performance.',
    icon: '<path d="M20 7h-9"></path><path d="M14 17H5"></path><circle cx="17" cy="17" r="3"></circle><circle cx="7" cy="7" r="3"></circle>'
  },
  {
    title: 'AI & Backend Integration',
    description: 'Exploring and implementing AI-driven solutions using Langchain and LangGraph, bridging the gap between LLMs and established backend infrastructures.',
    icon: '<path d="M12 3c.132 0 .263 0 .393 0a7.5 7.5 0 0 0 7.92 12.446a9 9 0 1 1-8.313-12.454z"></path><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"></path>'
  }
];
---

<section id="impact" class="py-20 border-t border-slate-200">
  <div class="space-y-12">
    <div>
      <h2 class="text-3xl font-bold text-slate-900 mb-2">Architectural Impact</h2>
      <p class="text-slate-600">Key technical milestones and problem-solving highlights.</p>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      {impacts.map(impact => (
        <div class="p-8 rounded-3xl bg-white border border-slate-100 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all group">
          <div class="w-14 h-14 rounded-2xl bg-blue-50 text-blue-600 flex items-center justify-center mb-6 group-hover:bg-blue-600 group-hover:text-white transition-all duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={impact.icon}>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-3">{impact.title}</h3>
          <p class="text-slate-600 leading-relaxed text-sm">
            {impact.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
