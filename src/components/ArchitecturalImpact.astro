---
import impacts from '../data/impacts.json';
---

<section id="impact" class="py-20 border-t border-slate-200">
  <div class="space-y-12">
    <div>
      <h2 class="text-3xl font-bold text-slate-900 mb-2">
        Architectural Impact
      </h2>
      <p class="text-slate-600">
        Key technical milestones and problem-solving highlights.
      </p>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      {
        impacts.map((impact) => (
          <div class="p-8 rounded-3xl bg-white border border-slate-100 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all group">
            <div class="w-14 h-14 rounded-2xl bg-blue-50 text-blue-600 flex items-center justify-center mb-6 group-hover:bg-blue-600 group-hover:text-white transition-all duration-300">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="28"
                height="28"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                set:html={impact.icon}
              />
            </div>
            <h3 class="text-xl font-bold text-slate-900 mb-3">
              {impact.title}
            </h3>
            <p class="text-slate-600 leading-relaxed text-sm">
              {impact.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
