---
const impacts = [
  {
    title: 'Distributed Systems',
    description: 'Designed a multi-region service mesh using HashiCorp Consul, ensuring 99.99% availability for critical payment processing services.',
    icon: 'M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z'
  },
  {
    title: 'Database Optimization',
    description: 'Refactored legacy PostgreSQL schemas and implemented advanced indexing strategies, reducing average query time from 1.2s to 80ms.',
    icon: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z'
  },
  {
    title: 'Cloud Infrastructure',
    description: 'Spearheaded the migration from monolithic on-premise servers to a serverless AWS architecture, resulting in a 35% reduction in infrastructure costs.',
    icon: 'M17.5 19h-11c-2.5 0-4.5-2-4.5-4.5 0-2 1.3-3.7 3.2-4.2.5-2.8 2.9-5 5.8-5 2.1 0 3.9 1.1 5 2.8 1-.6 2.1-.9 3.3-.9 3.2 0 5.8 2.6 5.8 5.8 0 3.3-2.6 6-5.8 6z'
  }
];
---

<section id="impact" class="py-20 border-t border-slate-200">
  <div class="space-y-12">
    <div>
      <h2 class="text-3xl font-bold text-slate-900 mb-2">Architectural Impact</h2>
      <p class="text-slate-600">Key technical milestones and problem-solving highlights.</p>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      {impacts.map(impact => (
        <div class="p-8 rounded-3xl bg-white border border-slate-100 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all group">
          <div class="w-14 h-14 rounded-2xl bg-blue-50 text-blue-600 flex items-center justify-center mb-6 group-hover:bg-blue-600 group-hover:text-white transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d={impact.icon}></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-3">{impact.title}</h3>
          <p class="text-slate-600 leading-relaxed text-sm">
            {impact.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
